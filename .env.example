# Copy this file to .env and fill in your values.
#   cp .env.example .env
# Never commit .env to git (it's in .gitignore).
# For Android AdMob App ID, also set android/secrets.properties (see android/secrets.properties.example).

# API
API_BASE_URL=https://api.imagifyai.io/api/v1

# Google Sign-In (Web Client ID from Firebase/Google Cloud Console)
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# AdMob (from admob.google.com)
ADMOB_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
ADMOB_REWARDED_AD_UNIT_ID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
ADMOB_INTERSTITIAL_AD_UNIT_ID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
